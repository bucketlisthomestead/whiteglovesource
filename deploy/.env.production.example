# Production environment for Docker Compose on EC2.
# Copy to /opt/wgs/.env on the server (user-data creates this from Secrets Manager).
# Do NOT commit real secrets.

NODE_ENV=production
PORT=3000

# RDS MySQL (shared across blue/green EC2 instances)
DB_HOST=wgsstack-dbinstance.xxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USERNAME=wgds
DB_PASSWORD=change-me
DB_DATABASE=white_glove_delivery

# Set true only on first boot against empty RDS, then false
TYPEORM_SYNCHRONIZE=false

JWT_SECRET=change-me

# Storage: s3 on EC2 (IAM role), local for dev
STORAGE_BACKEND=s3
S3_BUCKET=wgs-app-bucket-name
AWS_REGION=us-east-1

# Empty = same-origin (nginx serves frontend + proxies /api)
CORS_ORIGIN=
