# Local production-like environment (LocalStack S3 + Secrets Manager, local MySQL).
# Used by deploy/docker-compose.localstack.yml and native backend dev.
#
#   cp .env.localstack.example .env.localstack
#
# Add to /etc/hosts:
#   127.0.0.1 local.whiteglovesource.com
#
# App URL (nginx on :80): http://local.whiteglovesource.com

NODE_ENV=development
PORT=3000

# Database — matches docker-compose.yml mysql service (host.docker.internal from app containers)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=wgds
DB_PASSWORD=change-me
DB_DATABASE=white_glove_delivery
TYPEORM_SYNCHRONIZE=true

# Required for seed demo users on first backend start
DEV_ADMIN_PASSWORD=change-me

JWT_SECRET=localstack-dev-jwt-secret-change-me

# Mirror EC2 production: S3 via LocalStack (not local disk)
STORAGE_BACKEND=s3
S3_BUCKET=wgs-local-app
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
# Path-style LocalStack URL (optional; uploads still served via /api/files)
S3_PUBLIC_BASE_URL=http://localhost:4566/wgs-local-app

# Same-origin via nginx — leave as local domain (no port)
CORS_ORIGIN=http://local.whiteglovesource.com

# Email — Mailpit from docker-compose.yml
OWNER_EMAIL=hello@whiteglovedeliverync.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=White Glove Source <noreply@whiteglovedeliverync.com>
MAILPIT_WEB_URL=http://localhost:8025
MAILPIT_API_URL=http://localhost:8025

# LocalStack init / deploy scripts (optional overrides)
# WGS_LOCAL_BUCKET=wgs-local-app
# LOCALSTACK_ENDPOINT=http://localhost:4566
