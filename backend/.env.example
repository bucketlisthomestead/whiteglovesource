PORT=3001
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=wgds
DB_PASSWORD=change-me
DB_DATABASE=white_glove_delivery
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=wgds-dev-secret-change-in-production

# Required for seed demo users on first backend start (local dev only)
DEV_ADMIN_PASSWORD=change-me

# Object storage — production uses S3 on EC2; local disk when unset
# STORAGE_BACKEND=local
# STORAGE_BACKEND=s3
# S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=http://localhost:4566
# S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com

# Email — local dev uses Mailpit (npm run mail:up). Messages appear at http://localhost:8025
OWNER_EMAIL=hello@whiteglovedeliverync.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=White Glove Source <noreply@whiteglovedeliverync.com>
MAILPIT_WEB_URL=http://localhost:8025
MAILPIT_API_URL=http://localhost:8025

# Production SMTP (replace Mailpit settings above)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
