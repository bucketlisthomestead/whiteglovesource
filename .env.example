# Local dev secrets — copy to .env (gitignored) and set your own values.
# Docker Compose reads this file automatically from the repo root.
#
#   cp .env.example .env
#   cp backend/.env.example backend/.env
#
# Use the same DB_PASSWORD in both files. Set DEV_ADMIN_PASSWORD in backend/.env
# for seed demo users; set E2E_ADMIN_PASSWORD to match when running Playwright tests.

DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Optional — Playwright / deploy smoke (must match DEV_ADMIN_PASSWORD for seeded admin)
# E2E_ADMIN_PASSWORD=change-me
